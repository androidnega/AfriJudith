# =============================================================
# afriJudith.online — shared-hosting / cPanel safe Apache config
# =============================================================
# Anything that is illegal in a per-directory .htaccess (like
# <Directory>, <DirectoryMatch>, Options-without-IfModule, etc.)
# WILL crash Apache with a 500. Everything here is wrapped in
# IfModule guards so a missing module is harmless.
# =============================================================

DirectoryIndex index.php

AddDefaultCharset UTF-8

# Disable directory listings + content negotiation only if the
# host allows the Options override. cPanel usually does, but
# we wrap it so a stricter host doesn't 500.
<IfModule mod_autoindex.c>
    Options -Indexes
</IfModule>
<IfModule mod_negotiation.c>
    Options -MultiViews
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # ----- 1. Block direct access to framework folders ---------
    # (Defense in depth — there's also a Require-all-denied
    #  .htaccess inside each of these folders.)
    RewriteRule ^(app|config|tools)(/|$)        -  [F,L]

    # ----- 2. Block sensitive files at the docroot -------------
    RewriteRule ^(router\.php|README\.md|DEPLOY\.md|\.gitignore|composer\.(json|lock))$  -  [F,L]

    # ----- 3. Hide .php from URLs ------------------------------
    # If a visitor explicitly types /foo.php, redirect to /foo.
    RewriteCond %{THE_REQUEST} \s/+([^\s?]+?)\.php(?:\?[^\s]*)?\s [NC]
    RewriteRule ^ /%1 [R=301,L,NE]

    # Strip /index.php from any URL.
    RewriteCond %{THE_REQUEST} \s/+index\.php(?:\?[^\s]*)?\s [NC]
    RewriteRule ^ / [R=301,L,NE]

    # ----- 4. Let real files & directories serve themselves ----
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # ----- 5. Internally serve /foo if /foo.php exists ---------
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.+?)/?$ $1.php [L]

    # ----- 6. Front controller for everything else -------------
    RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
</IfModule>

# Gzip text-like responses if mod_deflate is available.
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/json image/svg+xml
</IfModule>

# Long-cache static assets.
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/png            "access plus 30 days"
    ExpiresByType image/jpeg           "access plus 30 days"
    ExpiresByType image/webp           "access plus 30 days"
    ExpiresByType image/svg+xml        "access plus 30 days"
    ExpiresByType text/css             "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType font/woff2           "access plus 365 days"
</IfModule>

# Security headers.
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), camera=(), microphone=()"
</IfModule>
